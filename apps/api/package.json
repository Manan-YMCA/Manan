{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --filter @manan/validations build && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "auth:generate": "npx @better-auth/cli generate --config ./src/auth/auth.ts"
  },
  "dependencies": {
    "@manan/validations": "workspace:*",
    "@better-auth/drizzle-adapter": "latest",
    "better-auth": "latest",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "http-status": "^2.1.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.7",
    "resend": "^6.10.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@better-auth/cli": "latest",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.9.0",
    "drizzle-kit": "^0.31.4",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}